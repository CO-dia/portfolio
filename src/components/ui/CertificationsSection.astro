---
interface Props {
  certifications: {
    name: string
    issuer?: string
    time: string
    status?: string
    link?: string
  }[]
}

const { certifications } = Astro.props
---

<section class="mb-12">
  <h2 class="text-2xl font-bold mb-6 border-b pb-2">Certifications</h2>
  <div class="grid gap-4">
    {
      certifications.map((cert) => (
        <div class="p-6 bg-base-200 rounded-xl">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="text-lg font-semibold text-base-content mb-1">
                {cert.name}
              </h3>
              {
                cert.issuer && (
                  <p class="text-sm text-base-content/70 mb-1">
                    {cert.issuer}
                  </p>
                )
              }
              <div class="text-sm text-base-content/70">
                {cert.time}
                {cert.status && ` • ${cert.status}`}
              </div>
            </div>
            {
              cert.link && (
                <a
                  href={cert.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-primary hover:underline"
                >
                  View →
                </a>
              )
            }
          </div>
        </div>
      ))
    }
  </div>
</section>
