---
import { Icon } from 'astro-icon/components'

interface Props {
  categories: {
    title: string
    skills: {
      name: string
      icon?: string
    }[]
  }[]
}

const { categories } = Astro.props
---

<section class="mb-12">
  <h2 class="text-2xl font-bold mb-6 border-b pb-2">Skills</h2>
  <div class="grid gap-8">
    {
      categories.map((category) => (
        <div class="p-6 bg-base-200 rounded-xl">
          <h3 class="text-xl font-semibold mb-4 text-base-content">
            {category.title}
          </h3>
          <div class="flex flex-wrap gap-4">
            {category.skills.map((skill) => (
              <div class="flex items-center gap-2 px-4 py-2 bg-base-100 rounded-lg border border-base-300 hover:border-primary/50 transition-colors">
                {skill.icon ? (
                  <div class="skill-icon-container" data-icon={skill.icon}>
                    <Icon
                      name={skill.icon}
                      class="w-6 h-6 flex-shrink-0 skill-icon"
                    />
                  </div>
                ) : (
                  <div class="w-6 h-6 rounded bg-primary/20 flex items-center justify-center flex-shrink-0">
                    <span class="text-xs font-semibold text-primary">
                      {skill.name.charAt(0).toUpperCase()}
                    </span>
                  </div>
                )}
                <span class="text-base-content font-medium">{skill.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style is:global>
  /* Make skill icons inherit text color and adapt to theme */
  .skill-icon {
    color: currentColor;
  }

  /* In dark themes, icons will be white due to text-base-content */
  html[data-theme='dark'] .skill-icon,
  html[data-theme='night'] .skill-icon,
  html[data-theme='synthwave'] .skill-icon,
  html[data-theme='dracula'] .skill-icon {
    color: currentColor;
  }
</style>

<script>
  // Generic code icon SVG
  const genericIcon = `
    <svg class="w-6 h-6 flex-shrink-0 text-base-content" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
    </svg>
  `

  // Handle missing icons by replacing with generic icon
  function replaceWithGenericIcon(container) {
    container.innerHTML = genericIcon
  }

  function checkAndReplaceIcons() {
    const iconContainers = document.querySelectorAll('.skill-icon-container')
    
    iconContainers.forEach((container) => {
      const icon = container.querySelector('.skill-icon')
      if (!icon) {
        replaceWithGenericIcon(container)
        return
      }
      // astro-icon renders the SVG with class "skill-icon" directly (icon IS the svg)
      const svg = icon.tagName === 'svg' ? icon : icon.querySelector('svg')
      const isEmpty = !svg || svg.children.length === 0 || (svg.innerHTML && svg.innerHTML.trim() === '')
      if (isEmpty) {
        replaceWithGenericIcon(container)
      }
    })
  }

  // Check on DOM load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      // Check immediately and after a delay
      checkAndReplaceIcons()
      setTimeout(checkAndReplaceIcons, 200)
    })
  } else {
    checkAndReplaceIcons()
    setTimeout(checkAndReplaceIcons, 200)
  }

  // Also check after Astro view transitions
  document.addEventListener('astro:after-swap', () => {
    setTimeout(checkAndReplaceIcons, 100)
  })
</script>
