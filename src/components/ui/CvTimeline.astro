---
import { isExperience } from '@/types/cv'
import type { Experience, Education } from '@/types/cv'
import { Building2, MapPin } from 'lucide-react'

interface Props {
  elements: (Experience | Education)[]
  colored: boolean
}

const { elements, colored } = Astro.props
---

<div class="grid gap-6">
  {
    elements.map((element) => (
      <div class="p-6 bg-base-200 rounded-xl">
        <div class="flex items-start justify-between mb-3">
          <div>
            <h3 class="text-xl font-semibold text-base-content mb-1">
              {isExperience(element) ? element.title : element.degree}
            </h3>
            <div class="text-sm text-base-content/70 flex flex-wrap items-center gap-x-2 gap-y-0.5">
              <span class="flex items-center gap-1.5">
                <Building2 className="size-4 shrink-0" />
                {isExperience(element) ? element.company : element.school}
              </span>
              {element.location && (
                <>
                  <span aria-hidden="true">•</span>
                  <span class="flex items-center gap-1.5">
                    <MapPin className="size-4 shrink-0" />
                    {element.location}
                  </span>
                </>
              )}
              <span aria-hidden="true">•</span>
              <time class="font-mono italic">{element.time}</time>
            </div>
          </div>
        </div>
        {element.description && (
          <div class="text-base-content whitespace-pre-line text-sm leading-relaxed">
            {element.description}
          </div>
        )}
      </div>
    ))
  }
</div>
