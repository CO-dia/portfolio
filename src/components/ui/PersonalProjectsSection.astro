---
import { template } from '@/settings'
import type { PersonalProject } from '@/data/cv'
import TechBadge from '@/components/ui/TechBadge.astro'

interface Props {
  projects: PersonalProject[]
  title?: string
}

const { projects, title = 'Personal Projects' } = Astro.props
---

<section class="mb-12">
  <h2 class="text-2xl font-bold mb-6 border-b pb-2">{title}</h2>
  <div class="grid gap-6">
    {
      projects.map((project) => (
        <div class="p-6 bg-base-200 rounded-xl">
          <div class="flex items-start justify-between mb-3">
            <div>
              <h3 class="text-xl font-semibold text-base-content mb-1">
                <a
                  href={`${template.base}/projects/${project.slug}`}
                  class="hover:text-primary hover:underline"
                >
                  {project.name}
                </a>
              </h3>
              <div class="text-sm text-base-content/70">
                {project.time}
                {project.location && ` • ${project.location}`}
              </div>
            </div>
            <div class="flex items-center gap-3">
              <a
                href={`${template.base}/projects/${project.slug}`}
                class="text-primary hover:underline text-sm"
              >
                Read more
              </a>
              {
                project.link && (
                  <a
                    href={project.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-primary hover:underline"
                  >
                    View site →
                  </a>
                )
              }
            </div>
          </div>
          <p class="text-base-content mb-4">{project.description}</p>
          <div class="mb-4 flex flex-wrap gap-2 items-center">
            <span class="text-sm font-semibold text-base-content/70 mr-1">
              Technologies:
            </span>
            {project.technologies.map((tech) => (
              <TechBadge name={tech} size="sm" />
            ))}
          </div>
          {
            project.details && project.details.length > 0 && (
              <ul class="list-disc list-inside space-y-1 text-base-content">
                {project.details.map((detail) => (
                  <li>{detail}</li>
                ))}
              </ul>
            )
          }
        </div>
      ))
    }
  </div>
</section>
