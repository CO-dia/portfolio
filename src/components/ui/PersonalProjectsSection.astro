---
interface Props {
  projects: {
    name: string
    time: string
    location?: string
    description: string
    technologies: string[]
    link?: string
    details?: string[]
  }[]
}

const { projects } = Astro.props
---

<section class="mb-12">
  <h2 class="text-2xl font-bold mb-6 border-b pb-2">Personal Projects</h2>
  <div class="grid gap-6">
    {
      projects.map((project) => (
        <div class="p-6 bg-base-200 rounded-xl">
          <div class="flex items-start justify-between mb-3">
            <div>
              <h3 class="text-xl font-semibold text-base-content mb-1">
                {project.name}
              </h3>
              <div class="text-sm text-base-content/70">
                {project.time}
                {project.location && ` • ${project.location}`}
              </div>
            </div>
            {
              project.link && (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-primary hover:underline"
                >
                  View →
                </a>
              )
            }
          </div>
          <p class="text-base-content mb-4">{project.description}</p>
          <div class="mb-4">
            <span class="text-sm font-semibold text-base-content/70">
              Technologies:{' '}
            </span>
            <span class="text-sm text-base-content">
              {project.technologies.join(' • ')}
            </span>
          </div>
          {
            project.details && project.details.length > 0 && (
              <ul class="list-disc list-inside space-y-1 text-base-content">
                {project.details.map((detail) => (
                  <li>{detail}</li>
                ))}
              </ul>
            )
          }
        </div>
      ))
    }
  </div>
</section>
